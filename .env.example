# Configuración del Servidor
PORT=3000

# Configuración de Envío de Email (SMTP)
# Reemplaza con tus credenciales SMTP reales para habilitar el envío de correos
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-usuario@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion

# Email destinatario donde se recibirán las consultas
CONTACT_RECEIVER=galatrobautista@gmail.com
